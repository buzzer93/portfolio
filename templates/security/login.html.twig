<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin — Connexion</title>
    <link rel="shortcut icon" href="{{ asset('images/braces-line.svg') }}" type="image/x-icon" />
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: "Poppins", sans-serif;
            background-color: hsl(228, 25%, 7%);
            color: hsl(220, 15%, 76%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }

        .login-card {
            background-color: hsl(228, 20%, 11%);
            border: 1px solid hsl(228, 15%, 18%);
            border-radius: 0.75rem;
            width: 100%;
            max-width: 400px;
            padding: 2.5rem 2rem;
        }

        .login-logo {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            justify-content: center;
            margin-bottom: 2rem;
            color: hsl(220, 30%, 92%);
            font-weight: 600;
            font-size: 1.125rem;
            letter-spacing: 0.01em;
        }

        .login-logo i { color: hsl(46, 90%, 58%); font-size: 1.35rem; }
        .login-logo span { color: hsl(46, 90%, 58%); }

        .login-title {
            font-size: 0.75rem;
            font-weight: 600;
            color: hsl(46, 90%, 58%);
            letter-spacing: 0.1em;
            text-transform: uppercase;
            text-align: center;
            margin-bottom: 1.75rem;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 0.375rem;
            margin-bottom: 1rem;
        }

        label {
            font-size: 0.8rem;
            color: hsl(220, 30%, 92%);
            font-weight: 500;
        }

        .input-wrap {
            position: relative;
        }

        .input-wrap i {
            position: absolute;
            left: 0.875rem;
            top: 50%;
            transform: translateY(-50%);
            color: hsl(220, 15%, 50%);
            font-size: 1rem;
            pointer-events: none;
        }

        input[type="email"],
        input[type="password"] {
            width: 100%;
            padding: 0.75rem 0.875rem 0.75rem 2.5rem;
            background-color: hsl(228, 25%, 7%);
            border: 1px solid hsl(228, 15%, 18%);
            border-radius: 0.375rem;
            color: hsl(220, 30%, 92%);
            font-family: inherit;
            font-size: 0.875rem;
            outline: none;
            transition: border-color 0.2s;
        }

        input[type="email"]:focus,
        input[type="password"]:focus {
            border-color: hsl(46, 90%, 58%);
        }

        .alert-error {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            background-color: hsla(0, 70%, 65%, 0.1);
            border: 1px solid hsla(0, 70%, 65%, 0.3);
            border-radius: 0.375rem;
            color: hsl(0, 70%, 70%);
            font-size: 0.8rem;
            padding: 0.625rem 0.875rem;
            margin-bottom: 1.25rem;
        }

        .btn-submit {
            width: 100%;
            margin-top: 0.5rem;
            padding: 0.75rem;
            background-color: hsl(46, 90%, 58%);
            color: hsl(228, 25%, 7%);
            border: none;
            border-radius: 0.375rem;
            font-family: inherit;
            font-size: 0.875rem;
            font-weight: 600;
            cursor: pointer;
            transition: opacity 0.2s, transform 0.2s;
        }

        .btn-submit:hover { opacity: 0.88; transform: translateY(-1px); }

        .back-link {
            display: block;
            text-align: center;
            margin-top: 1.25rem;
            font-size: 0.8rem;
            color: hsl(220, 15%, 50%);
            text-decoration: none;
            transition: color 0.2s;
        }

        .back-link:hover { color: hsl(46, 90%, 58%); }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-logo">
            <i class="ri-braces-line"></i>
            N.<span>Rodriguez</span>
        </div>

        <p class="login-title">Administration</p>

        {% if error %}
            <div class="alert-error">
                <i class="ri-error-warning-line"></i>
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form method="post">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}" />

            <div class="form-group">
                <label for="email">Email</label>
                <div class="input-wrap">
                    <i class="ri-mail-line"></i>
                    <input type="email"
                           id="email"
                           name="email"
                           value="{{ last_username }}"
                           autocomplete="email"
                           required
                           autofocus />
                </div>
            </div>

            <div class="form-group">
                <label for="password">Mot de passe</label>
                <div class="input-wrap">
                    <i class="ri-lock-line"></i>
                    <input type="password"
                           id="password"
                           name="password"
                           autocomplete="current-password"
                           required />
                </div>
            </div>

            <button type="submit" class="btn-submit">Se connecter</button>
        </form>

        <a href="{{ path('home') }}" class="back-link">
            <i class="ri-arrow-left-line"></i> Retour au portfolio
        </a>
    </div>
</body>
</html>
