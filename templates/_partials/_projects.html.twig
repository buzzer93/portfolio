<section class="projects section" id="projects">
    <h2 class="section-title">Mes <span>Projets</span></h2>
    <div class="projects-container container grid">
        {% for project in projects %}
            {% set descriptionHtml = (project.description|markdown_to_html) ~ '' %}
            {% set descriptionPreview = descriptionHtml|striptags|trim %}
            {% set techStackHtml = project.techStack ? (project.techStack|markdown_to_html) ~ '' : '' %}
            {% set projectInfo = {
                title: project.title,
                descriptionHtml: descriptionHtml,
                description: project.description,
                techStackHtml: techStackHtml,
                images: project.images,
                githubUrl: project.githubUrl
            }|json_encode %}
            <article class="projects-card">
                <img src="{{ asset('images/' ~ project.images[0]) }}" alt="{{ project.title }}" class="projects-img" />
                <div class="projects-modal">
                    <h2 class="projects-title">{{ project.title }}</h2>
                    <p class="projects-description">{{ descriptionPreview }}</p>
                    <button class="projects-button"
                            data-action="project-modal#open"
                            data-project-info="{{ projectInfo|e('html_attr') }}">
                        Voir le projet <i class="ri-eye-line"></i>
                    </button>
                </div>
            </article>
        {% endfor %}
    </div>
</section>
