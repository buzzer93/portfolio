{% extends 'admin/layout.html.twig' %}

{% block title %}Profil{% endblock %}
{% block page_title %}Profil{% endblock %}

{% block content %}
<style>
    .profile-grid {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 1.5rem;
        align-items: start;
    }
    @media (max-width: 900px) {
        .profile-grid { grid-template-columns: 1fr; }
    }
    .profile-col { display: flex; flex-direction: column; gap: 1.25rem; }

    .skills-cols {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem;
    }
    @media (max-width: 640px) {
        .skills-cols { grid-template-columns: 1fr; }
    }

    .skill-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.375rem;
        min-height: 2.25rem;
        margin-bottom: 0.75rem;
        padding: 0.5rem;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 0.375rem;
    }
    .skill-tags-empty {
        font-size: 0.75rem;
        color: var(--text);
        opacity: 0.5;
        align-self: center;
    }
    .skill-tag {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 0.25rem;
        padding: 0.2rem 0.45rem;
        font-size: 0.78rem;
        color: var(--title);
    }
    .skill-tag-remove {
        background: none;
        border: none;
        color: var(--text);
        cursor: pointer;
        font-size: 0.9rem;
        padding: 0 0.1rem;
        line-height: 1;
        opacity: 0.55;
        margin-left: 0.1rem;
    }
    .skill-tag-remove:hover { color: var(--danger); opacity: 1; }

    .skill-add-row {
        display: grid;
        grid-template-columns: 1fr 1fr auto;
        gap: 0.5rem;
        align-items: center;
    }
</style>

{{ form_start(form, {attr: {enctype: 'multipart/form-data'}}) }}

<div class="profile-grid">

    {# ── Left column : about + skills ── #}
    <div class="profile-col">

        <div class="card">
            <div class="form-group">
                {{ form_label(form.aboutText) }}
                {{ form_widget(form.aboutText, {attr: {class: 'form-control'}}) }}
                {{ form_errors(form.aboutText) }}
            </div>
        </div>

        <div class="card">
            <h2 style="font-size:0.8125rem; font-weight:600; color:var(--title); margin-bottom:1.25rem; text-transform:uppercase; letter-spacing:0.06em;">Compétences</h2>
            <div class="skills-cols">

                {# Front-end #}
                <div class="form-group">
                    <label style="font-size:0.8125rem; font-weight:500; color:var(--title); margin-bottom:0.5rem; display:block;">Front-end</label>
                    <div
                        data-controller="skill-list"
                        data-skill-list-skills-value="{{ profile.frontendSkills|json_encode }}"
                    >
                        <div data-skill-list-target="tags" class="skill-tags"></div>
                        <div class="skill-add-row">
                            <input type="text"
                                   data-skill-list-target="labelInput"
                                   placeholder="HTML5"
                                   class="form-control"
                                   data-action="keydown->skill-list#addOnEnter">
                            <input type="text"
                                   data-skill-list-target="iconInput"
                                   placeholder="ri-html5-fill"
                                   class="form-control"
                                   data-action="keydown->skill-list#addOnEnter">
                            <button type="button" class="btn btn-ghost btn-sm" data-action="skill-list#add">+</button>
                        </div>
                        {{ form_widget(form.frontendSkills, {attr: {'data-skill-list-target': 'output'}}) }}
                    </div>
                    {{ form_errors(form.frontendSkills) }}
                </div>

                {# Back-end & tools #}
                <div class="form-group">
                    <label style="font-size:0.8125rem; font-weight:500; color:var(--title); margin-bottom:0.5rem; display:block;">Back-end & Outils</label>
                    <div
                        data-controller="skill-list"
                        data-skill-list-skills-value="{{ profile.backendSkills|json_encode }}"
                    >
                        <div data-skill-list-target="tags" class="skill-tags"></div>
                        <div class="skill-add-row">
                            <input type="text"
                                   data-skill-list-target="labelInput"
                                   placeholder="Symfony"
                                   class="form-control"
                                   data-action="keydown->skill-list#addOnEnter">
                            <input type="text"
                                   data-skill-list-target="iconInput"
                                   placeholder="devicon-symfony-original"
                                   class="form-control"
                                   data-action="keydown->skill-list#addOnEnter">
                            <button type="button" class="btn btn-ghost btn-sm" data-action="skill-list#add">+</button>
                        </div>
                        {{ form_widget(form.backendSkills, {attr: {'data-skill-list-target': 'output'}}) }}
                    </div>
                    {{ form_errors(form.backendSkills) }}
                </div>

            </div>
            <p style="font-size:0.73rem; color:var(--text); opacity:0.6; margin-top:0.75rem;">
                Icônes&nbsp;: <a href="https://remixicon.com" target="_blank" style="color:var(--accent);">remixicon.com</a>
                ou <a href="https://devicon.dev" target="_blank" style="color:var(--accent);">devicon.dev</a>
            </p>
        </div>

    </div>

    {# ── Right column : photo + cv + save ── #}
    <div class="profile-col">

        <div class="card">
            <h2 style="font-size:0.8125rem; font-weight:600; color:var(--title); margin-bottom:1rem; text-transform:uppercase; letter-spacing:0.06em;">Photo de profil</h2>

            {% if profile.photoPath %}
            <div style="margin-bottom:1rem;">
                <img src="{{ asset('images/profile/' ~ profile.photoPath) }}"
                     alt="Photo actuelle"
                     style="width:72px; height:72px; object-fit:cover; border-radius:50%; border:2px solid var(--accent);" />
                <p style="font-size:0.73rem; color:var(--text); margin-top:0.375rem; opacity:0.7;">Photo actuelle — téléverser une nouvelle pour la remplacer</p>
            </div>
            {% endif %}

            <div class="form-group">
                {{ form_label(form.photoFile) }}
                {{ form_widget(form.photoFile, {attr: {class: 'form-control'}}) }}
                {{ form_errors(form.photoFile) }}
            </div>
        </div>

        <div class="card">
            <h2 style="font-size:0.8125rem; font-weight:600; color:var(--title); margin-bottom:1rem; text-transform:uppercase; letter-spacing:0.06em;">CV</h2>

            {% if profile.cvPath %}
            <p style="font-size:0.8rem; color:var(--success); margin-bottom:0.75rem;">
                <i class="ri-file-pdf-line"></i>
                CV en ligne —
                <a href="{{ asset('files/' ~ profile.cvPath) }}" target="_blank" style="color:var(--accent);">télécharger</a>
                · téléverser un nouveau fichier pour le remplacer
            </p>
            {% endif %}

            <div class="form-group">
                {{ form_label(form.cvFile) }}
                {{ form_widget(form.cvFile, {attr: {class: 'form-control'}}) }}
                {{ form_errors(form.cvFile) }}
            </div>
        </div>

        <div>
            <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center;">
                <i class="ri-save-line"></i> Enregistrer
            </button>
        </div>

    </div>

</div>

{{ form_end(form) }}
{% endblock %}
