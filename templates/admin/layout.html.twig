<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin — {% block title %}Portfolio{% endblock %}</title>
    <link rel="shortcut icon" href="{{ asset('images/braces-line.svg') }}" type="image/x-icon" />
    <link href="https://cdn.jsdelivr.net/npm/remixicon/fonts/remixicon.css" rel="stylesheet" />
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg:        hsl(228, 25%, 7%);
            --surface:   hsl(228, 20%, 11%);
            --border:    hsl(228, 15%, 18%);
            --accent:    hsl(46, 90%, 58%);
            --accent-dk: hsl(46, 70%, 46%);
            --text:      hsl(220, 15%, 76%);
            --title:     hsl(220, 30%, 92%);
            --danger:    hsl(0, 70%, 65%);
            --success:   hsl(142, 60%, 55%);
            --sidebar-w: 220px;
        }

        body {
            font-family: "Poppins", sans-serif;
            background: var(--bg);
            color: var(--text);
            font-size: 0.875rem;
            min-height: 100vh;
            display: flex;
        }

        a { text-decoration: none; color: inherit; }
        button { font-family: inherit; cursor: pointer; }
        input, textarea, select { font-family: inherit; }

        /* ── Sidebar ── */
        .sidebar {
            position: fixed;
            top: 0; left: 0;
            width: var(--sidebar-w);
            height: 100vh;
            background: var(--surface);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 1.5rem 0;
            z-index: 100;
        }

        .sidebar-logo {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0 1.25rem 1.5rem;
            border-bottom: 1px solid var(--border);
            margin-bottom: 1.25rem;
            color: var(--title);
            font-weight: 600;
            font-size: 0.9375rem;
        }

        .sidebar-logo i { color: var(--accent); font-size: 1.25rem; }
        .sidebar-logo span { color: var(--accent); }

        .sidebar-nav { flex: 1; display: flex; flex-direction: column; gap: 0.25rem; padding: 0 0.75rem; }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 0.625rem;
            padding: 0.625rem 0.75rem;
            border-radius: 0.375rem;
            color: var(--text);
            font-weight: 500;
            transition: background 0.15s, color 0.15s;
        }

        .nav-item i { font-size: 1.1rem; width: 1.25rem; text-align: center; }

        .nav-item:hover, .nav-item.active {
            background: hsla(46, 90%, 58%, 0.1);
            color: var(--accent);
        }

        .sidebar-footer {
            padding: 1rem 1.25rem 0;
            border-top: 1px solid var(--border);
        }

        .btn-logout {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            width: 100%;
            padding: 0.5rem 0.75rem;
            background: transparent;
            border: 1px solid var(--border);
            border-radius: 0.375rem;
            color: var(--text);
            font-size: 0.8125rem;
            transition: border-color 0.15s, color 0.15s;
        }

        .btn-logout:hover { border-color: var(--danger); color: var(--danger); }

        /* ── Main ── */
        .admin-main {
            margin-left: var(--sidebar-w);
            flex: 1;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .admin-header {
            padding: 1.25rem 2rem;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .admin-header h1 {
            font-size: 1.125rem;
            font-weight: 600;
            color: var(--title);
        }

        .admin-content { padding: 2rem; flex: 1; }

        /* ── Flash ── */
        .flash { padding: 0.75rem 1rem; border-radius: 0.375rem; margin-bottom: 1.5rem; font-size: 0.8125rem; display: flex; align-items: center; gap: 0.5rem; }
        .flash-success { background: hsla(142,60%,55%,0.1); border: 1px solid hsla(142,60%,55%,0.3); color: var(--success); }
        .flash-error   { background: hsla(0,70%,65%,0.1);   border: 1px solid hsla(0,70%,65%,0.3);   color: var(--danger); }

        /* ── Card ── */
        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 0.625rem;
            padding: 1.5rem;
        }

        /* ── Table ── */
        .admin-table { width: 100%; border-collapse: collapse; }
        .admin-table th { text-align: left; padding: 0.625rem 0.875rem; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--accent); border-bottom: 1px solid var(--border); }
        .admin-table td { padding: 0.875rem; border-bottom: 1px solid var(--border); vertical-align: middle; }
        .admin-table tr:last-child td { border-bottom: none; }
        .admin-table tr:hover td { background: hsla(228,20%,14%,0.5); }

        /* ── Buttons ── */
        .btn { display: inline-flex; align-items: center; gap: 0.375rem; padding: 0.5rem 1rem; border-radius: 0.375rem; font-size: 0.8125rem; font-weight: 500; border: none; transition: opacity 0.15s, transform 0.15s; }
        .btn:hover { opacity: 0.85; transform: translateY(-1px); }
        .btn-primary { background: var(--accent); color: hsl(228,25%,7%); }
        .btn-ghost   { background: transparent; border: 1px solid var(--border); color: var(--title); }
        .btn-ghost:hover { border-color: var(--accent); color: var(--accent); opacity: 1; }
        .btn-danger  { background: transparent; border: 1px solid hsla(0,70%,65%,0.4); color: var(--danger); }
        .btn-danger:hover { border-color: var(--danger); opacity: 1; }
        .btn-sm { padding: 0.3rem 0.625rem; font-size: 0.75rem; }

        /* ── Forms ── */
        .form-grid { display: grid; gap: 1.25rem; }
        .form-group { display: flex; flex-direction: column; gap: 0.375rem; }
        .form-group label { font-size: 0.8125rem; font-weight: 500; color: var(--title); }
        .form-group .help { font-size: 0.75rem; color: var(--text); opacity: 0.7; }
        .form-control {
            padding: 0.625rem 0.875rem;
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: 0.375rem;
            color: var(--title);
            font-size: 0.875rem;
            width: 100%;
            transition: border-color 0.2s;
        }
        .form-control:focus { outline: none; border-color: var(--accent); }
        textarea.form-control { resize: vertical; }
        .form-error { font-size: 0.75rem; color: var(--danger); margin-top: 0.25rem; }

        /* ── Drag handle ── */
        .drag-handle { cursor: grab; color: var(--border); font-size: 1.1rem; padding: 0 0.25rem; }
        .drag-handle:active { cursor: grabbing; }
        .sortable-ghost { opacity: 0.4; background: hsla(46,90%,58%,0.05); }

        /* ── Image grid ── */
        .img-grid { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 0.75rem; }
        .img-item { position: relative; }
        .img-item img { width: 120px; height: 80px; object-fit: cover; border-radius: 0.375rem; border: 1px solid var(--border); display: block; }
        .img-item label { display: flex; align-items: center; gap: 0.25rem; font-size: 0.7rem; color: var(--danger); margin-top: 0.25rem; cursor: pointer; }

        /* ── Badge ── */
        .badge { display: inline-block; padding: 0.15rem 0.5rem; border-radius: 0.25rem; font-size: 0.7rem; background: var(--bg); border: 1px solid var(--border); color: var(--title); }

        /* ── Project cards grid (dashboard) ── */
        .projects-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.25rem;
        }

        @media (max-width: 1100px) { .projects-grid { grid-template-columns: repeat(2, 1fr); } }
        @media (max-width: 640px)  { .projects-grid { grid-template-columns: 1fr; } }

        .admin-project-card {
            position: relative;
            border-radius: 0.5rem;
            overflow: hidden;
            border-top: 3px solid var(--accent);
            box-shadow: 0 4px 24px rgba(0,0,0,0.25);
            transition: box-shadow 0.2s, transform 0.2s;
            cursor: default;
        }

        .admin-project-card:hover {
            box-shadow: 0 12px 40px rgba(0,0,0,0.4), 0 0 0 1px hsla(46,90%,58%,0.15);
            transform: translateY(-3px);
        }

        .admin-card-img {
            width: 100%;
            aspect-ratio: 16/9;
            object-fit: cover;
            display: block;
        }

        .card-drag-handle {
            position: absolute;
            top: 0.5rem;
            left: 0.5rem;
            z-index: 2;
            background: rgba(0,0,0,0.55);
            color: var(--title);
            border-radius: 0.25rem;
            width: 1.75rem;
            height: 1.75rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            cursor: grab;
            opacity: 0;
            transition: opacity 0.15s;
        }

        .admin-project-card:hover .card-drag-handle { opacity: 1; }
        .card-drag-handle:active { cursor: grabbing; }

        .admin-card-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, transparent 30%, hsla(228,25%,7%,0.95) 70%);
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            align-items: center;
            padding: 1rem;
            gap: 0.5rem;
            opacity: 0;
            transition: opacity 0.2s;
        }

        .admin-project-card:hover .admin-card-overlay { opacity: 1; }

        .admin-card-title {
            font-size: 0.8125rem;
            font-weight: 600;
            color: var(--accent);
            text-align: center;
            letter-spacing: 0.04em;
            text-transform: uppercase;
        }

        .admin-card-tech {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 0.25rem;
        }

        .admin-tech-tag {
            padding: 0.1rem 0.375rem;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 0.25rem;
            font-size: 0.65rem;
            color: var(--title);
        }

        .admin-card-actions { display: flex; gap: 0.5rem; align-items: center; }

        .sortable-ghost { opacity: 0.35; outline: 2px dashed var(--accent); outline-offset: -2px; }
    </style>
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
    {% block head %}{% endblock %}
</head>
<body>
    <aside class="sidebar">
        <div class="sidebar-logo">
            <i class="ri-braces-line"></i>
            N.<span>Rodriguez</span>
        </div>

        <nav class="sidebar-nav">
            <a href="{{ path('admin_dashboard') }}"
               class="nav-item {{ app.request.attributes.get('_route') in ['admin_dashboard'] or app.request.attributes.get('_route') starts with 'admin_project' ? 'active' : '' }}">
                <i class="ri-folder-line"></i> Projets
            </a>
            <a href="{{ path('admin_profile_edit') }}"
               class="nav-item {{ app.request.attributes.get('_route') starts with 'admin_profile' ? 'active' : '' }}">
                <i class="ri-user-line"></i> Profil
            </a>
            <a href="{{ path('home') }}" target="_blank" class="nav-item">
                <i class="ri-eye-line"></i> Voir le site
            </a>
        </nav>

        <div class="sidebar-footer">
            <form method="post" action="{{ path('admin_logout') }}">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}" />
                <button type="submit" class="btn-logout">
                    <i class="ri-logout-box-line"></i> Déconnexion
                </button>
            </form>
        </div>
    </aside>

    <div class="admin-main">
        <header class="admin-header">
            <h1>{% block page_title %}Admin{% endblock %}</h1>
            <span style="font-size:0.8rem; color:var(--text);">{{ app.user.email ?? '' }}</span>
        </header>

        <div class="admin-content">
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash flash-{{ type }}">
                        <i class="ri-{{ type == 'success' ? 'checkbox-circle' : 'error-warning' }}-line"></i>
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            {% block content %}{% endblock %}
        </div>
    </div>
</body>
</html>
