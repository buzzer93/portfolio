{% extends 'admin/layout.html.twig' %}

{% set is_edit = project.id is not null %}
{% block title %}{{ is_edit ? 'Modifier' : 'Nouveau' }} projet{% endblock %}
{% block page_title %}{{ is_edit ? 'Modifier' : 'Nouveau' }} projet{% endblock %}

{% block head %}
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
{% endblock %}

{% block content %}
<style>
    .skill-tags-empty {
        font-size: 0.75rem;
        color: var(--text);
        opacity: 0.5;
        align-self: center;
    }

    .skill-tag {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 0.25rem;
        padding: 0.2rem 0.45rem;
        font-size: 0.78rem;
        color: var(--title);
    }

    .skill-tag-remove {
        background: none;
        border: none;
        color: var(--text);
        cursor: pointer;
        font-size: 0.9rem;
        padding: 0 0.1rem;
        line-height: 1;
        opacity: 0.55;
        margin-left: 0.1rem;
    }

    .skill-tag-remove:hover {
        color: var(--danger);
        opacity: 1;
    }

    .stack-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.375rem;
        min-height: 2.25rem;
        margin-bottom: 0.75rem;
        padding: 0.5rem;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 0.375rem;
    }

    .stack-selects {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.5rem;
    }

    .stack-category {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    .stack-category-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--accent);
        font-weight: 600;
    }

    @media (max-width: 900px) {
        .stack-selects { grid-template-columns: 1fr; }
    }
</style>

{{ form_start(form, {attr: {enctype: 'multipart/form-data', class: 'form-grid'}}) }}

    <div class="card">
        <div class="form-grid">

            <div class="form-group">
                {{ form_label(form.title) }}
                {{ form_widget(form.title, {attr: {class: 'form-control'}}) }}
                {{ form_errors(form.title) }}
            </div>

            <div class="form-group">
                {{ form_label(form.description) }}
                {{ form_widget(form.description, {attr: {class: 'form-control'}}) }}
                {{ form_errors(form.description) }}
            </div>

            <div class="form-group">
                {{ form_label(form.githubUrl) }}
                {{ form_widget(form.githubUrl, {attr: {class: 'form-control', placeholder: 'https://github.com/user/repo'}}) }}
                {{ form_errors(form.githubUrl) }}
            </div>

            <div class="form-group" data-controller="project-stack">
                <label>Stack technique</label>

                <div class="stack-selects">
                    <div class="stack-category">
                        <span class="stack-category-label">Front-end</span>
                        <div data-project-stack-target="frontendTags" class="skill-tags stack-tags"></div>
                        <select class="form-control" data-category="frontend" data-action="change->project-stack#addFromSelect">
                            <option value="">Ajouter une techno...</option>
                            {% for skill in frontendSkillOptions|default([]) %}
                                <option value="{{ skill }}">{{ skill }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="stack-category">
                        <span class="stack-category-label">Back-end</span>
                        <div data-project-stack-target="backendTags" class="skill-tags stack-tags"></div>
                        <select class="form-control" data-category="backend" data-action="change->project-stack#addFromSelect">
                            <option value="">Ajouter une techno...</option>
                            {% for skill in backendSkillOptions|default([]) %}
                                <option value="{{ skill }}">{{ skill }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="stack-category">
                        <span class="stack-category-label">Outils</span>
                        <div data-project-stack-target="toolsTags" class="skill-tags stack-tags"></div>
                        <select class="form-control" data-category="tools" data-action="change->project-stack#addFromSelect">
                            <option value="">Ajouter un outil...</option>
                            {% for skill in toolSkillOptions|default([]) %}
                                <option value="{{ skill }}">{{ skill }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>

                <span class="help">Choisissez dans les listes pour ajouter des tags sans faute de frappe.</span>
                {{ form_widget(form.techStack, {attr: {'data-project-stack-target': 'output'}}) }}
                {{ form_errors(form.techStack) }}
            </div>

            <div class="form-group" style="max-width:160px;">
                {{ form_label(form.position) }}
                {{ form_widget(form.position, {attr: {class: 'form-control'}}) }}
                {{ form_errors(form.position) }}
            </div>

            <div class="form-group" style="align-self:end;">
                <label style="display:flex; gap:0.5rem; align-items:center; font-size:0.85rem; color:var(--title);">
                    {{ form_widget(form.isActive) }}
                    {{ form.isActive.vars.label }}
                </label>
                {{ form_errors(form.isActive) }}
            </div>

        </div>
    </div>

    <div class="card">
        <h2 style="font-size:0.8125rem; font-weight:600; color:var(--title); margin-bottom:1rem; text-transform:uppercase; letter-spacing:0.06em;">Images</h2>
        <input type="hidden" name="image_order" id="image-order-input" value='{{ project.images|json_encode|e('html_attr') }}' />

        {% if is_edit and project.images|length > 0 %}
        <p style="font-size:0.8rem; color:var(--text); margin-bottom:0.75rem;">Images actuelles — glissez pour réorganiser le carousel, cochez pour supprimer :</p>
        <div class="img-grid" id="sortable-project-images" style="margin-bottom:1.5rem;">
            {% for image in project.images %}
            <div class="img-item" data-image="{{ image|e('html_attr') }}">
                <span class="card-drag-handle" style="opacity:1; top:0.4rem; left:0.4rem;" title="Réorganiser">
                    <i class="ri-draggable"></i>
                </span>
                <img src="{{ asset('images/' ~ image) }}" alt="{{ project.title }}" />
                <label>
                    <input type="checkbox" name="delete_images[]" value="{{ image }}" />
                    Supprimer
                </label>
            </div>
            {% endfor %}
        </div>
        {% endif %}

        <div class="form-group">
            {{ form_label(form.imageFiles) }}
            {{ form_widget(form.imageFiles, {attr: {class: 'form-control'}}) }}
            {{ form_errors(form.imageFiles) }}
        </div>
    </div>

    <div style="display:flex; gap:0.75rem;">
        <button type="submit" class="btn btn-primary">
            <i class="ri-save-line"></i> {{ is_edit ? 'Enregistrer' : 'Créer' }}
        </button>
        <a href="{{ path('admin_dashboard') }}" class="btn btn-ghost">Annuler</a>
    </div>

{{ form_end(form) }}

{% if is_edit and project.images|length > 0 %}
<script>
(() => {
    const grid = document.getElementById('sortable-project-images');
    const output = document.getElementById('image-order-input');
    if (!grid || !output) return;

    const syncOrder = () => {
        const ordered = Array.from(grid.querySelectorAll('.img-item'))
            .map((item) => item.dataset.image)
            .filter(Boolean);
        output.value = JSON.stringify(ordered);
    };

    Sortable.create(grid, {
        handle: '.card-drag-handle',
        animation: 180,
        ghostClass: 'sortable-ghost',
        onEnd: syncOrder,
    });

    syncOrder();
})();
</script>
{% endif %}
{% endblock %}
